@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Lora:wght@400;600;700&display=swap');

:root {
    --bg-primary: #ffffff;
    --bg-secondary: #f9fafb;
    --accent-primary: #2563eb;
    --accent-secondary: #10b981;
    --accent-surface: #eff6ff;
    --text-main: #111827;
    --text-dim: #4b5563;
    --glass-bg: rgba(255, 255, 255, 0.7);
    --glass-border: #e5e7eb;
    --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    --transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    --font-heading: 'Lora', serif;
    --font-body: 'Outfit', sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: var(--bg-primary);
    color: var(--text-main);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
}

/* --- Background Pattern --- */
.bg-mesh {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: 
        radial-gradient(circle at 100% 0%, rgba(37, 99, 235, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 0% 100%, rgba(16, 185, 129, 0.03) 0%, transparent 40%);
    pointer-events: none;
}

/* --- Navigation --- */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 1.5rem 10%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--glass-border);
}

.logo {
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.5px;
    color: var(--text-main);
    transition: var(--transition);
}

.logo:hover {
    color: var(--accent-primary);
}

.nav-links {
    display: flex;
    gap: 2rem;
}

.nav-links a {
    color: var(--text-dim);
    text-decoration: none;
    font-weight: 400;
    transition: var(--transition);
    font-size: 0.9rem;
}

.nav-links a:hover {
    color: var(--accent-primary);
}

/* --- Hero Section --- */
header {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 0 15%;
    position: relative;
    background: url('assets/hero-bg.png') no-repeat center right;
    background-size: 50%;
}

.hero-tagline {
    font-size: 1rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 4px;
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s forwards;
}

h1 {
    font-family: var(--font-heading);
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2rem;
    letter-spacing: -1px;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s 0.2s forwards;
}

.highlight {
    color: var(--accent-primary);
    position: relative;
}

.hero-description {
    max-width: 580px;
    color: var(--text-dim);
    font-size: 1.25rem;
    line-height: 1.7;
    margin-bottom: 3.5rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s 0.4s forwards;
}

.btn {
    padding: 1rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: var(--transition);
    border: none;
    cursor: pointer;
    font-size: 1rem;
}

.btn-primary {
    background: var(--accent-primary);
    color: #fff;
}

.btn-primary:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(0, 242, 255, 0.4);
}

/* --- Bento Grid Section --- */
section {
    padding: 100px 10%;
}

h2 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    margin-bottom: 3rem;
}

.section-title {
    border-bottom: 2px solid var(--text-main);
    padding-bottom: 0.5rem;
    display: inline-block;
    margin-bottom: 3rem;
    font-size: 1.8rem;
    letter-spacing: -1px;
}

/* --- Hero Section --- */
header {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 120px 10%;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
}

.hero-container {
    max-width: 900px;
}

.featured-tag {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-primary);
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
}

.hero-description {
    font-size: 1.3rem;
    color: var(--text-dim);
    margin-bottom: 3rem;
}

/* --- Main Layout --- */
.main-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 5rem;
    padding: 80px 10%;
    max-width: 1400px;
    margin: 0 auto;
}

/* --- Feed Section --- */
.feed-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
}

.feed-img {
    flex: 0 0 200px;
    height: 200px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--accent-primary);
    transition: var(--transition);
}

.feed-item:hover .feed-img {
    transform: scale(1.03);
}

.feed-content h3 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    line-height: 1.3;
    margin: 0.5rem 0 1rem;
    transition: var(--transition);
}

.feed-content h3:hover {
    color: var(--accent-primary);
}

.feed-content p {
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
}

.tag {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--accent-primary);
    letter-spacing: 1px;
}

.meta {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
}

.read-more {
    text-decoration: none;
    color: var(--text-main);
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition);
}

.read-more:hover {
    gap: 0.8rem;
    color: var(--accent-primary);
}

/* --- Sidebar --- */
.sidebar {
    display: flex;
    flex-direction: column;
    gap: 4rem;
}

.sidebar-widget h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--text-main);
    padding-bottom: 0.5rem;
}

.expertise-list {
    list-style: none;
}

.expertise-list li {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-dim);
}

.expertise-list li i {
    color: var(--accent-primary);
}

.newsletter-form input {
    width: 100%;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-secondary);
    margin-bottom: 1rem;
}

/* --- Contact Section --- */
.contact-section {
    padding: 100px 10%;
    background: var(--bg-secondary);
    text-align: center;
}

.contact-btns {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
}

.btn-outline {
    border: 2px solid var(--accent-primary);
    color: var(--accent-primary);
    background: transparent;
}

.btn-outline:hover {
    background: var(--accent-primary);
    color: #fff;
}

/* --- Animations --- */
@keyframes fadeInUp {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* --- Custom Scrollbar --- */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--accent-primary);
}

/* --- Responsive --- */
@media (max-width: 1100px) {
    .main-layout {
        grid-template-columns: 1fr;
        gap: 4rem;
    }
    h1 { font-size: 3.5rem; }
}

@media (max-width: 768px) {
    section, header, .main-layout {
        padding: 60px 5%;
    }

    .feed-item {
        flex-direction: column;
    }

    .feed-img {
        flex: 0 0 150px;
        height: 150px;
    }

    h1 { font-size: 2.8rem; }
    .nav-links { display: none; }
}

/* --- Custom Cursor --- */
.custom-cursor {
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--accent-primary);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.15s ease;
    transform: translate(-50%, -50%);
}

.reveal-init {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.revealed {
    opacity: 1;
    transform: translateY(0);
}

